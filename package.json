{
  "name": "git-agent-cli",
  "version": "1.0.0",
  "description": "An autonomous CLI agent powered by local Ollama (no hardcoded model) for local Git management and direct GitHub edits via token - with planning, multi-step reasoning, and automatic context compression",
  "main": "bin/agent.js",
  "bin": {
    "devy-git": "./bin/agent.js",
    "gitagent": "./bin/agent.js"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node bin/agent.js",
    "chat": "node bin/agent.js chat",
    "selfcheck": "node scripts/selfcheck.js"
  },
  "dependencies": {
    "ansi-escapes": "^4.3.2",
    "boxen": "5.1.2",
    "chalk": "4.1.2",
    "cli-highlight": "^2.1.11",
    "dotenv": "16.4.5",
    "figures": "^3.2.0",
    "marked": "^4.3.0",
    "marked-terminal": "^6.2.0",
    "ora": "^5.4.1",
    "string-width": "^4.2.3",
    "wrap-ansi": "^7.0.0"
  },
  "license": "MIT",
  "author": "DevHive"
}
