# ===== Ollama (local - via Termux or any other machine) =====
# Local Ollama server address
OLLAMA_HOST=http://localhost:11434

# Optional: if set, the agent uses this model directly without prompting you to choose.
# Leave it empty to get an interactive list of models actually installed in your Ollama.
OLLAMA_MODEL=

# ===== GitHub (for direct repo edits via the API with no clone, and for Actions tools) =====
# Personal Access Token (classic or fine-grained) with repo + workflow scopes
GITHUB_TOKEN=

# Optional: default owner/repo the agent works on when not specified per command.
# IMPORTANT: this must be just the name (e.g. "my-repo"), NOT a full URL.
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=
GITHUB_DEFAULT_BRANCH=main

# ===== General agent settings =====
# Local repo path the agent operates on (for local git tools and the terminal tool).
# Leave empty to default to the current directory (like git itself) - this is what makes
# a global `devy-git` install work from any project you cd into. Only set this if you want
# to point the agent somewhere other than where you're running it from.
# A ".devy-agent" folder (plan, memory, tool-output cache) is created inside this directory.
WORKSPACE_DIR=

# Estimated max tokens in the context window (used if the model doesn't report its own context length)
DEFAULT_CONTEXT_TOKENS=8192

# Fill ratio (0-1) at which the agent starts compressing/summarizing older context
CONTEXT_COMPRESSION_THRESHOLD=0.65

# Max characters for any single tool output before it's truncated and cached in full
TOOL_OUTPUT_MAX_CHARS=4000

# Max number of steps (Thought/Action) in a single run before the agent stops and waits for input
MAX_AGENT_STEPS=40
